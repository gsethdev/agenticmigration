{
    "ScriptsVersion": "1.0.3",
    "PortalEndpoint": "https://portal.azure.com",
    "Environment": "AzureCloud",
    "PackagedSitesFolder": "packagedsites\\",
    "DefaultReadinessResultsFilePath": "ReadinessResults.json",
    "DefaultPackageResultsFileName": "PackageResults.json",
